{
    "name": "defectivecode/mjml",
    "description": "Compile MJML to responsive HTML emails directly in PHP without requiring Node.js. Wraps the official MJML engine with full Laravel integration.",
    "type": "laravel",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "DefectiveCode\\MJML\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DefectiveCode\\MJML\\Tests\\": "tests"
        }
    },
    "authors": [
        {
            "name": "Corey McCormick",
            "email": "corey@defectivecode.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0",
        "nunomaduro/collision": "^8.8 || ^9.0",
        "phpunit/phpunit": "^12.0",
        "laravel/pint": "^1.25"
    },
    "extra": {
        "laravel": {
            "providers": [
                "DefectiveCode\\MJML\\MJMLServiceProvider"
            ],
            "aliases": {
                "MJML": "DefectiveCode\\MJML\\Facade"
            }
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php vendor/bin/testbench package:discover --ansi"
        ]
    }
}
